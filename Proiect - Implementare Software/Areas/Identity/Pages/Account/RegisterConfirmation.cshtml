@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Register confirmation";
}

<style>
    body {
        background: linear-gradient(135deg, #40E0D0, #2f8f9d);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        overflow: hidden;
    }

    #splash-screen {
        position: absolute;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        z-index: 1000;
    }

    @@keyframes logoAnimation {
        0% {
            transform: scale(0.8);
        }

        50% {
            transform: scale(2.2);
        }

        100% {
            transform: scale(1.7);
        }
    }

    #splash-screen img {
        width: 250px;
        height: auto;
        animation: logoAnimation 2s cubic-bezier(0.25, 0.8, 0.25, 1) forwards;
    }

    .loading-spinner {
        border: 7px solid #f3f3f3;
        border-top: 4px solid #2f8f9d;
        border-radius: 50%;
        width: 60px;
        height: 60px;
        animation: spin 1s linear infinite;
        margin-top: 80px;
        margin-left: -15px;
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .loading-text {
        color: #2f8f9d;
        font-size: 24px;
        margin-top: 10px;
        font-weight: bold;
    }

    .confirmation-card {
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        width: 100%;
        max-width: 400px;
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 1s ease-in, transform 1s ease-in;
    }

        .confirmation-card.show {
            opacity: 1;
            transform: translateY(0);
        }

    h1 {
        text-align: center;
        color: #2f8f9d;
        margin-bottom: 20px;
        font-weight: 700;
    }

    a {
        color: #2f8f9d;
        text-decoration: none;
        transition: color 0.3s ease;
    }

        a:hover {
            color: #135e67;
        }

    .btn-primary {
        background-color: #40E0D0;
        border: none;
        transition: background-color 0.3s ease, transform 0.2s ease;
    }

        .btn-primary:hover {
            background-color: #2f8f9d;
            transform: translateY(-2px);
        }

    .btn-outline-primary {
        border-color: #40E0D0;
        color: #2f8f9d;
        transition: all 0.3s ease;
    }

        .btn-outline-primary:hover {
            background-color: #40E0D0;
            color: white;
        }

    .form-floating > label {
        color: #2f8f9d;
    }

    .form-check-input:checked {
        background-color: #40E0D0;
        border-color: #40E0D0;
    }

    /* Animation for fade-in */
    @@keyframes fadeIn {
        0% {
            opacity: 0;
            transform: translateY(-30px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .spinner-border-sm {
        width: 1rem;
        height: 1rem;
        border-width: 0.2em;
    }
</style>

<div id="splash-screen">
    <img src="~/images/logo.png" alt="Logo" />
    <div class="loading-spinner"></div>
    <div class="loading-text">Loading, please wait...</div>
</div>

<div class="confirmation-card">
    <h1>@ViewData["Title"]</h1>

    @if (@Model.DisplayConfirmAccountLink)
    {
        <p>
            A confirmation email has been sent to your address. Please check your inbox (or spam folder) to confirm your account.
        </p>
    }
    else
    {
        <p>
            Please check your email to confirm your account.
        </p>
    }

    <div class="text-center">
        <p><a href="@Model.EmailConfirmationUrl" class="btn btn-outline-primary">Resend confirmation email</a></p>
    </div>
</div>

@section Scripts {
    <script>
        window.onload = function () {
            setTimeout(function () {
                document.getElementById('splash-screen').style.display = 'none';
                document.querySelector('.confirmation-card').classList.add('show');
            }, 3000);
        };
    </script>
}
