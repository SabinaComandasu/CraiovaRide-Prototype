@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<style>
    body {
        background: linear-gradient(135deg, #40E0D0, #2f8f9d);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        overflow: hidden;
        margin: 0;
    }

    .container {
        max-width: 500px;
        width: 100%;
        background: white;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        padding: 40px;
        animation: fadeIn 1s ease-in;
    }

    h1 {
        text-align: center;
        color: #2f8f9d;
        font-weight: 700;
        margin-bottom: 10px;
        font-size: 32px;
    }

    h2 {
        text-align: center;
        color: #2f8f9d;
        font-size: 20px;
        margin-bottom: 30px;
    }

    hr {
        border: 1px solid #2f8f9d;
        margin-bottom: 30px;
        width: 50%;
        margin-left: auto;
        margin-right: auto;
    }

    .form-floating input {
        border-radius: 10px;
        border: 1px solid #2f8f9d;
        transition: all 0.3s ease;
    }

    .form-floating input:focus {
        border-color: #40E0D0;
        box-shadow: 0 0 5px rgba(64, 224, 208, 0.7);
    }

    .form-floating label {
        color: #2f8f9d;
        font-weight: bold;
    }

    .btn-primary {
        background-color: #40E0D0;
        border: none;
        width: 100%;
        padding: 12px;
        border-radius: 10px;
        transition: all 0.3s ease;
        font-size: 18px;
    }

    .btn-primary:hover {
        background-color: #2f8f9d;
        transform: translateY(-3px);
    }

    .btn-primary:focus {
        outline: none;
        box-shadow: 0 0 5px rgba(64, 224, 208, 0.7);
    }

    .error-message {
        color: red;
        text-align: center;
        font-weight: bold;
        margin-bottom: 20px;
    }

    /* Animation for fade-in */
    @@keyframes fadeIn {
        0% {
            opacity: 0;
            transform: translateY(-30px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Spinner for loading */
    .spinner-border-sm {
        width: 1rem;
        height: 1rem;
        border-width: 0.2em;
    }

</style>

<div class="container">
    <h1>@ViewData["Title"]</h1>
    <h2>Enter your email</h2>

    <hr />

    <form method="post">
        <!-- Error message container -->
        <div asp-validation-summary="ModelOnly" class="error-message" role="alert"></div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
            <label asp-for="Input.Email" class="form-label">Email address</label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-lg btn-primary">
            Reset Password
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
