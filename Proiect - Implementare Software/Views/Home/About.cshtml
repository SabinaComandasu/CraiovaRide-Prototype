@{
    ViewData["Title"] = "About";
    ViewData["ShowMainNav"] = true;
}
<link href="~/css/about.css" rel="stylesheet" />
<link href="~/css/animation.css" rel="stylesheet" />

<div class="about-container">
    <div class="about-logo">
        <img src="~/images/logo.png" alt="CraiovaRide Logo" />
    </div>

    <h1 class="about-title">About CraiovaRide</h1>
    <p class="about-subtitle">Modern, reliable, and student-driven ride-sharing in Craiova.</p>

    <section class="about-section">
        <h2>Our Vision</h2>
        <p>
            CraiovaRide was born from the desire to bring people closer. Developed by students from the Faculty of Automation, Computers, and Electronics in Craiova, our platform is a response to the growing need for fast, friendly, and flexible transportation in the city.
        </p>
        <p>
            We believe that mobility should be simple and accessible — whether you're heading to university, catching a train, or going out with friends. With CraiovaRide, you travel on your terms, in your own rhythm.
        </p>
    </section>

    <section class="about-section">
        <h2>Why Choose CraiovaRide?</h2>
        <ul class="about-offers">
            <li>✓ Easy-to-use interface, friendly even for first-time users</li>
            <li>✓ Instant ride requests with predictable prices and no surprises</li>
            <li>✓ Multiple payment options: card or cash — your choice</li>
            <li>✓ Transparent rating system to ensure safe, high-quality rides</li>
            <li>✓ View past rides and plan ahead with real-time availability</li>
        </ul>
    </section>

    <section class="about-section">
        <h2>Our Mission</h2>
        <p>
            At CraiovaRide, we want to reshape how people move through the city. By focusing on user experience, community feedback, and accessibility, our mission is to build trust in every journey. We're not just moving people — we're connecting lives.
        </p>
        <p>
            Whether you're a student running late to class, a commuter avoiding the crowded bus, or simply someone who values convenience, CraiovaRide is here to get you there, comfortably and safely.
        </p>
    </section>
</div>


<!-- Realistic Animated Landscape -->
<div class="country-wrap">
    <div class="mountain-1"></div>
    <div class="mountain-2"></div>
    <div class="sun"></div>
    <div class="grass"></div>

    <div class="street">
        <div class="car">
            <div class="car-body">
                <div class="car-top-back"><div class="back-curve"></div></div>
                <div class="car-gate"></div>
                <div class="car-top-front"><div class="wind-sheild"></div></div>
                <div class="bonet-front"></div>
                <div class="stepney"></div>
            </div>
            <div class="car-headlight"></div>
            <div class="car-headlight second-light"></div>

            <div class="boundary-tyre-cover">
                <div class="boundary-tyre-cover-back-bottom"></div>
                <div class="boundary-tyre-cover-inner"></div>
            </div>
            <div class="tyre-cover-front">
                <div class="boundary-tyre-cover-inner-front"></div>
            </div>
            <div class="base-axcel"></div>
            <div class="front-bumper"></div>
            <div class="tyre"><div class="gap"></div></div>
            <div class="tyre front"><div class="gap"></div></div>
            <div class="car-shadow"></div>
        </div>
        <div class="street-stripe"></div>
    </div>
    <div class="cloud"></div>

    <div class="hill">
        <div class="tree-1">
            <div class="branch-1"></div>
            <div class="branch-2"></div>
            <div class="branch-3"></div>
        </div>
        <div class="tree-1">
            <div class="branch"></div>
            <div class="trunk"></div>
        </div>
    </div>
</div>
