<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - CraiovaRide</title>

    <!-- Leaflet CSS & Routing -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />


    <!-- Custom CSS -->
    <link href="/css/home.css" rel="stylesheet">

    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.min.js"></script>

    <!-- Your JS -->
    <script src="/js/home.js" defer></script>
</head>
<body>
    <!-- Toggle Sidebar -->
    <button id="toggleBtn" class="toggle-btn" onclick="toggleSidebar()">&#9776;</button>

    <!-- Search Bar -->
    <div class="search-bar d-flex align-items-start gap-2 mb-3">
        <div class="flex-grow-1 position-relative">
            <input id="searchInput" type="text" class="form-control" placeholder="Find destination...">
            <div id="suggestions" class="autocomplete-container"></div>
        </div>
        <button class="btn btn-primary" onclick="searchLocation()">Search</button>
    </div>

    <!-- Sidebar -->
    <!-- Sidebar -->
    <div id="sidebar" class="sidebar">
        <img src="/images/avatar.png" class="img-thumbnail mb-2" alt="Profile photo">

        <!-- Rating-ul utilizatorului -->
        <div class="text-center mb-3">
            <strong>⭐ Rating:</strong> <span id="userRating">4.8</span>/5
        </div>

        <ul class="nav flex-column">
            <li class="nav-item"><a href="/Account#profile" class="nav-link">Profile</a></li>
            <li class="nav-item"><a href="/Payments" class="nav-link">Payments</a></li>
            <li class="nav-item"><a href="/PromoCodes" class="nav-link">Promo Codes</a></li>
            <li class="nav-item"><a href="/Rides#completed" class="nav-link">History of Rides</a></li>
            <li class="nav-item"><a href="/About" class="nav-link">About</a></li>
        </ul>
    </div>


    <!-- Overlay -->
    <div id="overlay" class="overlay" onclick="closeSidebar()"></div>

    <!-- Harta -->
    <div id="map" class="map-container"></div>

    <!-- Ride Options -->
    <div id="rideOptions" class="ride-options-container" style="display: none;">

        <div class="ride-options-scroll d-flex justify-content-start align-items-center gap-3 px-3 py-2">
            <div class="card ride-option" onclick="selectRide('Standard Ride')">
                <div class="card-body text-center">
                    <h6 class="card-title">🚗 Standard Ride</h6>
                    <p class="card-text">Affordable everyday rides</p>
                </div>
            </div>
            <div class="card ride-option" onclick="selectRide('Eco Ride')">
                <div class="card-body text-center">
                    <h6 class="card-title">🚕 Eco Ride</h6>
                    <p class="card-text">Electric vehicle</p>
                </div>
            </div>
            <div class="card ride-option" onclick="selectRide('Luggage')">
                <div class="card-body text-center">
                    <h6 class="card-title">🧳 Luggage</h6>
                    <p class="card-text">Extra trunk space</p>
                </div>
            </div>
            <div class="card ride-option" onclick="selectRide('Deluxe Ride')">
                <div class="card-body text-center">
                    <h6 class="card-title">🚘 Deluxe Ride</h6>
                    <p class="card-text">Premium experience</p>
                </div>
            </div>
            <div class="card ride-option" onclick="selectRide('Women for Women')">
                <div class="card-body text-center">
                    <h6 class="card-title">👩‍🦰 Women for Women</h6>
                    <p class="card-text">Female-only option</p>
                </div>
            </div>
        </div>
        <div class="ride-cancel-btn-container">
            <button id="cancelRideBtn" class="btn btn-danger" onclick="cancelRide()">Cancel Ride</button>
        </div>

    </div>

    <!-- Modal pentru eroare de plată -->
    <div id="paymentErrorModal" class="custom-modal" onclick="closePaymentModal(event)">
        <div class="custom-modal-content">
            <span class="close-btn" onclick="closePaymentModal(event)">&times;</span>
            <p class="modal-text">❌ Please select a payment method (Cash or Card) before choosing a ride.</p>
        </div>
    </div>


    <!-- Payment Options -->
    <div id="paymentOptions" class="payment-options-container" style="display: none;">
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="paymentMethod" id="cashOption" value="cash">
            <label class="form-check-label" for="cashOption">💵 Cash</label>
        </div>
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="paymentMethod" id="cardOption" value="card">
            <label class="form-check-label" for="cardOption">💳 Card</label>
        </div>
    </div>
    <!-- Modal Confirmare Ride -->
    <div id="rideConfirmationModal" class="custom-modal" onclick="closeRideModal(event)">
        <div class="custom-modal-content">
            <span class="close-btn" onclick="closeRideModal(event)">&times;</span>
            <p id="rideConfirmText" class="modal-text"></p>
        </div>
    </div>

    <!-- Modal Rating -->
    <div id="rideRatingModal" class="custom-modal" onclick="closeRatingModal(event)">
        <div class="custom-modal-content">
            <p class="modal-text">🟢 The ride has ended. Please rate your experience:</p>
            <div id="ratingStars" class="rating-stars"></div>
            <button id="submitRatingBtn" class="btn btn-success mt-3" style="display: none;" onclick="submitRating()">Submit Rating</button>
        </div>
    </div>
    <!-- Modal - Out of Service Area -->
    <div id="serviceAreaModal" class="custom-modal" onclick="closeServiceAreaModal(event)">
        <div class="custom-modal-content">
            <span class="close-btn" onclick="closeServiceAreaModal(event)">&times;</span>
            <p class="modal-text">⚠️ Sorry, our service is currently not available for this location.</p>
        </div>
    </div>


    <!-- Bottom Nav -->
    <div class="bottom-nav">
        <a href="/Home" class="btn btn-outline-secondary mx-2">Home</a>
        <a href="/Rides" class="btn btn-outline-primary mx-2">Rides</a>
        <a href="/Account" class="btn btn-outline-success mx-2">Account</a>
    </div>
</body>
</html>
