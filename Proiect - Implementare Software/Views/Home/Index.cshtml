<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - CraiovaRide</title>

    <!-- Leaflet CSS & Routing -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.css" />

    <!-- Custom CSS -->
    <link href="/css/home.css" rel="stylesheet">

    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.min.js"></script>

    <!-- Your JS -->
    <script src="/js/home.js" defer></script>
</head>
<body>
    <!-- Toggle Sidebar -->
    <button id="toggleBtn" class="toggle-btn" onclick="toggleSidebar()">&#9776;</button>

    <!-- Search Bar -->
    <div class="search-bar d-flex align-items-start gap-2 mb-3">
        <div class="flex-grow-1 position-relative">
            <input id="searchInput" type="text" class="form-control" placeholder="Find destination...">
            <div id="suggestions" class="autocomplete-container"></div>
        </div>
        <button class="btn btn-primary" onclick="searchLocation()">Search</button>
    </div>

    <!-- Sidebar -->
    <div id="sidebar" class="sidebar">

        <!-- ✅ Avatar, Name, and Rating -->
        <div class="d-flex align-items-start gap-3 mb-3">
            <img src="@ViewBag.AvatarPath" class="avatar-img" alt="Profile photo">
            <div class="text-start">
                <div class="fw-bold">@ViewBag.FullName</div>
                <div>⭐ @ViewBag.Rating</div>
            </div>
        </div>

        <!-- Sidebar Navigation -->
        <ul class="nav flex-column">
            <li class="nav-item"><a href="/Account#profile" class="nav-link">Profile</a></li>
            <li class="nav-item"><a href="/Payments" class="nav-link">Payments</a></li>
            <li class="nav-item"><a href="/PromoCodes" class="nav-link">Promo Codes</a></li>
            <li class="nav-item"><a href="/Rides#completed" class="nav-link">History of Rides</a></li>
            <li class="nav-item"><a href="/About" class="nav-link">About</a></li>
        </ul>

        <!-- Log Out Button -->
        <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="logout-form px-3">
            <button type="submit" class="nav-link logout-link w-100 text-start">
                <strong>Log Out</strong>
            </button>
        </form>
    </div>

    <!-- Overlay -->
    <div id="overlay" class="overlay" onclick="closeSidebar()"></div>

    <!-- Map -->
    <div id="map" class="map-container"></div>

    <!-- Ride Options -->
    <div id="rideOptions" class="container mt-4" style="display: none;">
        <h5>Choose your ride</h5>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="card ride-option" onclick="selectRide('Standard Ride')">
                    <div class="card-body text-center">
                        <h6 class="card-title">🚗 Standard Ride</h6>
                        <p class="card-text">Affordable everyday rides</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card ride-option" onclick="selectRide('Eco Ride')">
                    <div class="card-body text-center">
                        <h6 class="card-title">🚕 Eco Ride</h6>
                        <p class="card-text">Electric vehicle</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card ride-option" onclick="selectRide('Luggage')">
                    <div class="card-body text-center">
                        <h6 class="card-title">🧳 Luggage</h6>
                        <p class="card-text">Extra trunk space</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card ride-option" onclick="selectRide('Deluxe Ride')">
                    <div class="card-body text-center">
                        <h6 class="card-title">🚘 Deluxe Ride</h6>
                        <p class="card-text">Premium experience</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card ride-option" onclick="selectRide('Women for Women')">
                    <div class="card-body text-center">
                        <h6 class="card-title">👩‍🦰 Women for Women</h6>
                        <p class="card-text">Female-only option</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cancel Ride -->
        <div class="text-center mt-3">
            <button id="cancelRideBtn" class="btn btn-danger" onclick="cancelRide()">Cancel Ride</button>
        </div>
    </div>

    <!-- Bottom Nav -->
    <div class="bottom-nav">
        <a href="/Home" class="btn btn-outline-secondary mx-2">Home</a>
        <a href="/Rides" class="btn btn-outline-primary mx-2">Rides</a>
        <a href="/Account" class="btn btn-outline-success mx-2">Account</a>
    </div>

    <!-- Custom Sidebar Avatar Style -->
    <style>
        /* Sidebar layout */
        .sidebar {
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        /* Avatar */
        .avatar-img {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid #2f8f9d;
            box-shadow: 0 0 6px rgba(0, 0, 0, 0.1);
        }

        /* Navigation links (turquoise, oval) */
        .nav-link {
            background-color: #f0f0f0;
            border-radius: 25px;
            margin: 5px 0;
            padding: 10px 15px;
            font-weight: 500;
            color: #2f8f9d;
            transition: background-color 0.2s ease, color 0.2s ease;
            text-decoration: none;
        }

            .nav-link:hover {
                background-color: #e0e0e0;
                color: #135e67;
            }

        /* Logout form container pinned to bottom */
        .logout-form {
            margin-top: auto;
            padding: 1rem;
        }

            /* Logout button styled identically to nav-link */
            .logout-form button {
                display: block;
                width: 100%;
                background-color: #f0f0f0;
                border-radius: 25px;
                padding: 10px 15px;
                margin: 5px 0;
                font-weight: 500;
                color: #dc3545; /* red */
                text-align: left; /* ✅ aligns text to the left */
                border: none;
                transition: background-color 0.2s ease, color 0.2s ease;
                text-decoration: none !important;
            }

    </style>
</body>
</html>
