<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - CraiovaRide</title>
    <!-- 1. Leaflet CSS -->
    <link href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" rel="stylesheet">

    <!-- 2. Leaflet JS (trebuie să vină ÎNAINTE de orice script care folosește Leaflet) -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <!-- 3. Leaflet Routing Machine CSS și JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.css" />
    <script src="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.min.js"></script>

    <!-- 4. Scriptul tău custom (care folosește L) -->
    <script src="/js/home.js" defer></script>

    <link href="/css/home.css" rel="stylesheet">
</head>
<body>
    <!-- Buton de meniu -->
    <button id="toggleBtn" class="toggle-btn" onclick="toggleSidebar()">&#9776;</button>

    <!-- Search Bar plutitor -->
    <div class="search-bar d-flex align-items-start gap-2 mb-3">
        <div class="flex-grow-1 position-relative">
            <input id="searchInput" type="text" class="form-control" placeholder="Find destination...">
            <div id="suggestions" class="autocomplete-container"></div>
        </div>
        <button class="btn btn-primary" onclick="searchLocation()">Search</button>

    </div>


    <!-- Sidebar -->
    <div id="sidebar" class="sidebar">
        <img src="/images/avatar.png" class="img-thumbnail mb-3" alt="Profile photo">
        <ul class="nav flex-column">
            <li class="nav-item"><a href="/Account" class="nav-link">Profile</a></li>
            <li class="nav-item"><a href="/Ratings" class="nav-link">Rating</a></li>
            <li class="nav-item"><a href="/Payments" class="nav-link">Payments</a></li>
            <li class="nav-item"><a href="/PromoCodes" class="nav-link">Promo Codes</a></li>
            <li class="nav-item"><a href="/Rides/History" class="nav-link">History of Rides</a></li>
            <li class="nav-item"><a href="/About" class="nav-link">About</a></li>
        </ul>
    </div>

    <!-- Overlay -->
    <div id="overlay" class="overlay" onclick="closeSidebar()"></div>

    <!-- Harta -->
    <div id="map" class="map-container"></div>
    <div id="rideOptions" class="container mt-4" style="display: none;">
        <h5>Choose your ride</h5>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="card ride-option" onclick="selectRide('Standard Ride')">
                    <div class="card-body text-center">
                        <h6 class="card-title">🚗 Standard Ride</h6>
                        <p class="card-text">Affordable everyday rides</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card ride-option" onclick="selectRide('Eco Ride')">
                    <div class="card-body text-center">
                        <h6 class="card-title">🚕 Eco Ride</h6>
                        <p class="card-text">Electric vehicle</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card ride-option" onclick="selectRide('Luggage')">
                    <div class="card-body text-center">
                        <h6 class="card-title">🧳 Luggage</h6>
                        <p class="card-text">Extra trunk space</p>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!-- Bara de navigare jos -->
    <div class="bottom-nav">
        <a href="/Home" class="btn btn-outline-secondary mx-2">Home</a>
        <a href="/Rides" class="btn btn-outline-primary mx-2">Rides</a>
        <a href="/Account" class="btn btn-outline-success mx-2">Account</a>
    </div>
</body>
</html>
