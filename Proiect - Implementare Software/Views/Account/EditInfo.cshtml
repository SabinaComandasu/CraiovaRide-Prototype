@model Proiect_Implementare_Software.Models.Person

@{
    ViewData["Title"] = "Personal Information";
    ViewData["ShowMainNav"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/css/account.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<div class="container mt-4" style="max-width: 500px;">

    <!-- Avatar Upload -->
    <div class="text-center mb-4">
        <form asp-action="UploadAvatar" asp-controller="Account" method="post" enctype="multipart/form-data" class="d-inline-block">
            <div class="position-relative d-inline-block">
                <img src="@(string.IsNullOrEmpty(Model.Avatar) ? "/images/default-avatar.png" : "/images/" + Model.Avatar)" class="avatar-img shadow" />
                <label class="btn btn-light btn-sm position-absolute bottom-0 end-0 rounded-circle mb-0" style="cursor:pointer;">
                    <i class="bi bi-plus-circle-fill text-success"></i>
                    <input type="file" name="avatarFile" accept="image/*" class="d-none" onchange="this.form.submit()" />
                </label>
            </div>
        </form>
        <p class="text-muted mt-2">Add a profile picture</p>
    </div>

    <!-- Personal Info Form -->
    <form asp-action="EditInfo" asp-controller="Account" method="post">
        <div class="info-item mb-3">
            <label class="form-label"><i class="bi bi-person-fill me-2"></i> Full Name</label>
            <input type="text" name="FullName" class="form-control" value="@Model.FullName" required />
        </div>

        <div class="info-item mb-3">
            <label class="form-label"><i class="bi bi-phone-fill me-2"></i> Phone</label>
            <input type="tel" name="PhoneNumber" class="form-control" value="@Model.PhoneNumber" />
        </div>

        <button type="submit" class="btn btn-success w-100 mt-4">Save Changes</button>
    </form>
</div>
