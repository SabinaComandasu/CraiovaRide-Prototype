@model Proiect_Implementare_Software.Models.Person
@{
    ViewData["Title"] = "Informații personale";
    ViewData["ShowMainNav"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/css/account.css" />
<script src="~/js/editinfo.js"></script>

<div class="container mt-4" style="max-width: 500px;">

    <!-- Card avatar -->
    <div class="text-center mb-4">
        <div class="position-relative d-inline-block">
            <img src="@Model.Avatar" class="avatar-img shadow" />
            <button class="btn btn-light btn-sm position-absolute bottom-0 end-0 rounded-circle">
                <i class="bi bi-plus-circle-fill text-success"></i>
            </button>
        </div>
        <p class="text-muted mt-2">Adaugă o poză de profil</p>
    </div>

    <!-- Nume -->
    <div class="info-item d-flex justify-content-between align-items-center mb-3">
        <div>
            <label class="form-label"><i class="bi bi-person-fill me-2"></i> Nume complet</label>
            <div id="name-display">@Model.FullName</div>
            <input type="text" class="form-control d-none" id="name-input" value="@Model.FullName" />
        </div>
        <button class="btn btn-link text-success" onclick="toggleEdit('name')">Editează</button>
    </div>

    <!-- Telefon -->
    <div class="info-item d-flex justify-content-between align-items-center mb-3">
        <div>
            <label class="form-label"><i class="bi bi-phone-fill me-2"></i> Telefon</label>
            <div id="phone-display">@Model.PhoneNumber</div>
            <input type="tel" class="form-control d-none" id="phone-input" value="@Model.PhoneNumber" />
        </div>
        <button class="btn btn-link text-success" onclick="toggleEdit('phone')">Editează</button>
    </div>

    <!-- Buton Salvare -->
    <button class="btn btn-success w-100 mt-4">Salvează modificările</button>
</div>
