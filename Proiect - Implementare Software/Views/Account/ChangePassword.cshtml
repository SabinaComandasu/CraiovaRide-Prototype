@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isSuccess = ViewBag.StatusMessage?.ToString().Contains("successfully") == true;
}

<style>
    body {
        background: linear-gradient(135deg, #40E0D0, #2f8f9d);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        overflow: hidden;
    }

    .change-password-card {
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        width: 100%;
        max-width: 400px;
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 1s ease-in, transform 1s ease-in;
    }

    .change-password-card.show {
        opacity: 1;
        transform: translateY(0);
    }

    h1 {
        text-align: center;
        color: #2f8f9d;
        margin-bottom: 20px;
        font-weight: 700;
    }

    .btn-primary {
        background-color: #40E0D0;
        border: none;
        transition: background-color 0.3s ease, transform 0.2s ease;
    }

    .btn-primary:hover {
        background-color: #2f8f9d;
        transform: translateY(-2px);
    }

    .alert-success {
        background-color: #d4edda;
        color: #155724;
        padding: 15px;
        border-radius: 10px;
        margin-bottom: 20px;
        text-align: center;
    }
</style>

<div class="change-password-card" id="change-password-card">
    <h1>@ViewData["Title"]</h1>

    @if (ViewBag.StatusMessage != null)
    {
        <div class="alert-success" id="success-message">@ViewBag.StatusMessage</div>
    }

    @if (!isSuccess)
    {
        <form method="post" action="/Account/ChangePassword">
            <div class="form-group mb-3">
                <label for="currentPassword">Current Password</label>
                <input type="password" name="currentPassword" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label for="newPassword">New Password</label>
                <input type="password" name="newPassword" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label for="confirmPassword">Confirm New Password</label>
                <input type="password" name="confirmPassword" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">Update Password</button>
        </form>
    }
</div>

@section Scripts {
    <script>
        window.onload = function () {
            document.getElementById("change-password-card").classList.add("show");

            const successMessage = document.getElementById("success-message");
            if (successMessage) {
                setTimeout(function () {
                    window.location.href = "/Home/Index";
                }, 4000);
            }
        };
    </script>
}
