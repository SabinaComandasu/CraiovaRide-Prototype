@{
    ViewData["ShowMainNav"] = true;
    ViewData["Title"] = "My Account";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/css/account.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<div class="account-bolt container">
    <!-- Profile Header -->
    <div class="text-center profile-header">
        <div class="avatar-wrapper">
            <img src="@ViewBag.AvatarPath" alt="Avatar" class="avatar-img" />
        </div>
        <h4 class="username">@ViewBag.FullName</h4>
        <p class="rating text-success">
            <i class="bi bi-star-fill"></i> @ViewBag.Rating Rating
        </p>
    </div>

    <!-- Account Options -->
    <div class="section">
        <a href="/Account/EditInfo" class="section-item">
            <i class="bi bi-person-lines-fill"></i> Personal Information
        </a>
        <a href="/Account/TripSafety" class="section-item">
            <i class="bi bi-shield-lock-fill"></i> Safety
        </a>
        <a href="/Account/ChangePassword" class="section-item">
            <i class="bi bi-key-fill"></i> Change Password
        </a>

    </div>

  

    <!-- Final Settings -->
    <div class="section">
        <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="d-inline">
            <button type="submit" class="section-item text-danger btn btn-link p-0 m-0 align-baseline">
                <i class="bi bi-box-arrow-right"></i> Log Out
            </button>
        </form>

        <a href="/Account/Delete" class="section-item text-danger">
            <i class="bi bi-trash"></i> Delete Account
        </a>
    </div>
</div>
