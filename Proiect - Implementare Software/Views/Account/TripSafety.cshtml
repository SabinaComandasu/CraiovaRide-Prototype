@{
    ViewData["Title"] = "Trip Safety";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/css/safety.css" />
<script src="~/js/safety.js" defer></script>

<div class="container mt-5">
    <h3>Trip Safety Settings</h3>
    <form id="trustedContactForm">
        <div class="mb-3">
            <label for="trustedEmail" class="form-label">Trusted Contact Email</label>
            <input type="email" id="trustedEmail" class="form-control" required />
        </div>
        <button type="submit" class="btn btn-success">Save Contact</button>
        <div id="saveMessage" class="mt-3 text-success" style="display: none;">Contact saved successfully.</div>
    </form>
</div>
