@model List<Proiect_Implementare_Software.Models.Ride>
@using Proiect_Implementare_Software.Models

@{
    ViewData["Title"] = "Rides";
    ViewData["ShowMainNav"] = true;

    var now = DateTime.Now;
    var upcomingRides = Model.Where(r => r.RideStatus == "Scheduled" && r.Date > now).ToList();
    var completedRides = Model.Where(r => r.RideStatus == "Completed" || r.RideStatus == "Finished").ToList();

    var products = ViewBag.Products as List<Product> ?? new List<Product>();

    decimal totalAmount = upcomingRides
        .Where(r => r.Product != null)
        .Sum(r => r.Product!.Price);
}

<!-- Custom Turquoise Style -->
<style>
    .nav-tabs .nav-link {
        border-radius: 2rem;
        background-color: #e0f7f9;
        color: #007c91;
        transition: background-color 0.3s ease, color 0.3s ease;
    }

        .nav-tabs .nav-link.active {
            background-color: #00bcd4;
            color: white;
            font-weight: bold;
        }

    .tab-pane {
        animation: fadeIn 0.4s ease-in-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .card {
        border-radius: 1.25rem;
        border: none;
        background-color: #f0fcfc;
    }

    .form-control, .btn {
        border-radius: 1rem;
    }

    .btn-primary {
        background-color: #00acc1;
        border-color: #00acc1;
    }

        .btn-primary:hover {
            background-color: #00838f;
            border-color: #00838f;
        }

    label {
        font-weight: 500;
    }

    .alert {
        border-radius: 1rem;
    }

    .badge {
        font-size: 0.9rem;
        padding: 0.5em 0.75em;
        border-radius: 0.5rem;
    }

    .badge-scheduled {
        background-color: #ffeb3b;
        color: #333;
    }

    .badge-completed {
        background-color: #00c853;
        color: white;
    }

    .total-box {
        background-color: #e0f7f9;
        border-radius: 1.25rem;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .total-amount {
        font-size: 1.4rem;
        font-weight: 700;
        color: #00838f;
    }

    .btn-checkout {
        background-color: #00acc1;
        border: none;
        color: white;
        font-weight: 600;
        border-radius: 1rem;
        padding: 0.6rem 1.5rem;
        transition: background-color 0.2s ease;
    }

        .btn-checkout:hover {
            background-color: #00838f;
            color: white;
        }

    .ride-product-badge {
        display: inline-block;
        background-color: #b2ebf2;
        color: #006064;
        border-radius: 0.5rem;
        padding: 0.2em 0.6em;
        font-size: 0.85rem;
        font-weight: 500;
        margin-top: 4px;
    }
</style>

<div class="container mt-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <!-- Tabs -->
    <ul class="nav nav-tabs" id="ridesTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="upcoming-tab" data-bs-toggle="tab" data-bs-target="#upcoming" type="button" role="tab">Upcoming Rides</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="completed-tab" data-bs-toggle="tab" data-bs-target="#completed" type="button" role="tab">Completed Rides</button>
        </li>
    </ul>

    <div class="tab-content mt-1" id="ridesTabContent">
        <!-- Upcoming Tab -->
        <div class="tab-pane fade show active" id="upcoming" role="tabpanel">
            <!-- Schedule Ride Form -->
            <div class="card mb-2 p-4 shadow-sm">
                <h5 class="mb-3">Schedule a New Ride</h5>
                <form action="/Rides/Index" method="post">
                    <input type="hidden" name="RideID" value="0" />

                    <div class="mb-3">
                        <label for="PickupLocation" class="form-label">Pickup Location</label>
                        <input type="text" name="PickupLocation" id="PickupLocation" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label for="Destination" class="form-label">Destination</label>
                        <input type="text" name="Destination" id="Destination" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label for="Date" class="form-label">Date & Time</label>
                        <input type="datetime-local" name="Date" id="Date"
                               class="form-control"
                               min='@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")'
                               required />
                    </div>

                    <div class="mb-3">
                        <label for="ProductID" class="form-label">Ride Type</label>
                        <select name="ProductID" id="ProductID" class="form-control">
                            <option value="">-- Select a ride type --</option>
                            @{
                                var grouped = products.GroupBy(p => p.Category);
                                foreach (var group in grouped)
                                {
                                    <optgroup label="@group.Key">
                                        @foreach (var p in group)
                                        {
                                            <option value="@p.ProductID">@p.Icon @p.Name – @p.Price.ToString("F2") RON</option>
                                        }
                                    </optgroup>
                                }
                            }
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary">Submit</button>
                </form>
            </div>

            <!-- Total & Checkout -->
            @if (upcomingRides.Any())
            {
                <div class="total-box mb-3 shadow-sm">
                    <div>
                        <span class="text-muted">Total for scheduled rides:</span><br />
                        <span class="total-amount">@totalAmount.ToString("F2") RON</span>
                    </div>
                    <form action="/Rides/Checkout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-checkout"
                                onclick="return confirm('Confirm checkout? All scheduled rides will be cleared.')">
                            🛒 Checkout
                        </button>
                    </form>
                </div>

                @foreach (var ride in upcomingRides)
                {
                    <div class="card shadow-sm mb-3 p-3">
                        <h5>@ride.PickupLocation → @ride.Destination</h5>
                        <p class="mb-1">Scheduled for: @ride.Date.ToString("f")</p>
                        @if (ride.Product != null)
                        {
                            <div>
                                <span class="ride-product-badge">@ride.Product.Icon @ride.Product.Name</span>
                                <span class="ride-product-badge">@ride.Product.Price.ToString("F2") RON</span>
                            </div>
                        }
                        <div class="mt-2">
                            <span class="badge badge-scheduled">Scheduled</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="card shadow-sm p-3">
                    <p>No upcoming rides yet.</p>
                </div>
            }
        </div>

        <!-- Completed Tab -->
        <div class="tab-pane fade" id="completed" role="tabpanel">
            @if (completedRides.Any())
            {
                @foreach (var ride in completedRides)
                {
                    <div class="card shadow-sm mb-3 p-3">
                        <h5>@ride.PickupLocation → @ride.Destination</h5>
                        <p>Completed on: @ride.Date.ToString("f")</p>
                        @if (ride.Product != null)
                        {
                            <span class="ride-product-badge">@ride.Product.Icon @ride.Product.Name – @ride.Product.Price.ToString("F2") RON</span>
                        }
                        <div class="mt-2">
                            <span class="badge badge-completed">
                                @(ride.RideStatus == "Finished" ? "Completed" : ride.RideStatus)
                            </span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="card shadow-sm p-3 text-center">
                    <p class="text-muted">No completed rides yet.</p>
                </div>
            }
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<link href="/css/rides.css" rel="stylesheet" />
