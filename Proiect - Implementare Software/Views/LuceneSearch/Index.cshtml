@model List<Proiect_Implementare_Software.Services.LuceneSearchResult>

@{
    ViewData["Title"]       = "Cautare avansata";
    ViewData["ShowMainNav"] = true;

    string query       = ViewBag.Query ?? "";
    string sort        = ViewBag.Sort  ?? "desc";
    bool   hasQuery    = !string.IsNullOrWhiteSpace(query);
    int    resultCount = ViewBag.ResultCount ?? 0;

    string oppSort  = sort == "asc" ? "desc" : "asc";
    string oppLabel = sort == "asc"  ? "Relevanta ↓ (desc)" : "Relevanta ↑ (asc)";
    float  maxScore = Model.Any() ? Model.Max(r => r.Score) : 1f;
}

<style>
    /* ── Layout ── */
    .lucene-page {
        max-width: 820px;
        margin: 0 auto;
        padding: 30px 20px 80px;
        font-family: system-ui, sans-serif;
    }
    .lucene-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1a5f7a;
        margin-bottom: 4px;
    }
    .lucene-subtitle {
        font-size: 0.9rem;
        color: #666;
        margin-bottom: 24px;
    }

    /* ── Search bar ── */
    .lucene-form {
        display: flex;
        gap: 8px;
        margin-bottom: 14px;
    }
    .lucene-form input {
        flex: 1;
        border: 2px solid #2f8f9d;
        border-radius: 25px;
        padding: 10px 18px;
        font-size: 0.95rem;
        outline: none;
    }
    .lucene-form input:focus { border-color: #005fa3; }
    .lucene-form button {
        background: #2f8f9d;
        color: white;
        border: none;
        border-radius: 25px;
        padding: 10px 22px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
    }
    .lucene-form button:hover { background: #005fa3; }

    /* ── Sort + meta row ── */
    .meta-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }
    .meta-row .info {
        font-size: 0.88rem;
        color: #555;
        flex: 1;
    }
    .sort-btn {
        font-size: 0.82rem;
        padding: 5px 14px;
        border-radius: 20px;
        border: 1.5px solid #2f8f9d;
        background: white;
        color: #2f8f9d;
        cursor: pointer;
        text-decoration: none;
        white-space: nowrap;
    }
    .sort-btn:hover, .sort-btn.active {
        background: #2f8f9d;
        color: white;
        text-decoration: none;
    }

    /* ── Result cards ── */
    .result-list { display: flex; flex-direction: column; gap: 14px; }

    .result-card {
        background: #f5fbff;
        border: 1.5px solid #c8e6f5;
        border-radius: 12px;
        padding: 16px 18px;
        display: flex;
        gap: 16px;
        align-items: flex-start;
        text-decoration: none;
        color: inherit;
        transition: box-shadow 0.2s, transform 0.15s;
    }
    .result-card:hover {
        box-shadow: 0 4px 14px rgba(47,143,157,.2);
        transform: translateY(-2px);
        text-decoration: none;
        color: inherit;
    }
    .result-icon { font-size: 2rem; flex-shrink: 0; line-height: 1; }
    .result-body { flex: 1; min-width: 0; }
    .result-name {
        font-size: 1rem;
        font-weight: 700;
        color: #005fa3;
        margin-bottom: 2px;
    }
    .result-category {
        font-size: 0.78rem;
        color: #888;
        margin-bottom: 6px;
    }
    .result-snippet {
        font-size: 0.83rem;
        color: #444;
        line-height: 1.45;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 580px;
    }

    /* ── Score badge + bar ── */
    .score-col { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; flex-shrink: 0; }
    .score-badge {
        background: #e4f4fd;
        color: #005fa3;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 0.78rem;
        font-weight: 700;
        white-space: nowrap;
    }
    .score-bar-wrap { width: 80px; height: 6px; background: #dde; border-radius: 3px; overflow: hidden; }
    .score-bar { height: 100%; background: linear-gradient(90deg, #2f8f9d, #005fa3); border-radius: 3px; }

    /* ── Empty / no query states ── */
    .empty-state {
        text-align: center;
        padding: 50px 20px;
        color: #999;
    }
    .empty-state .big { font-size: 3rem; }
</style>

<div class="lucene-page">
    <h1 class="lucene-title">🔬 Cautare avansata in fisele tehnice</h1>
    <p class="lucene-subtitle">Cauta in documentele de specificatii ale tuturor serviciilor disponibile.</p>

    <!-- Search form -->
    <form method="get" action="/LuceneSearch" class="lucene-form">
        <input type="text"
               name="q"
               value="@query"
               placeholder="ex: transfer aeroport, livrare express, animale, Wi-Fi..."
               autocomplete="off" />
        <input type="hidden" name="sort" value="@sort" />
        <button type="submit">🔍 Cauta</button>
    </form>

    @if (hasQuery)
    {
        <!-- Meta row: result count + sort toggle -->
        <div class="meta-row">
            <span class="info">
                @if (resultCount > 0)
                {
                    <span><strong>@resultCount</strong> rezultat@(resultCount == 1 ? "" : "e") pentru <strong>„@query"</strong></span>
                }
                else
                {
                    <span>Niciun rezultat pentru <strong>„@query"</strong></span>
                }
            </span>

            @if (resultCount > 1)
            {
                <span class="sort-btn active" style="cursor:default;">
                    @(sort == "asc" ? "Relevanta ↑ (asc)" : "Relevanta ↓ (desc)")
                </span>
                <a class="sort-btn"
                   href="/LuceneSearch?q=@Uri.EscapeDataString(query)&sort=@oppSort">
                    @oppLabel
                </a>
            }
        </div>

        <!-- Results -->
        @if (Model.Any())
        {
            <div class="result-list">
                @foreach (var r in Model)
                {
                    var pct = maxScore > 0 ? (int)(r.Score / maxScore * 100) : 0;

                    <a href="/Products/Details/@r.ProductId" class="result-card">
                        <span class="result-icon">@r.Icon</span>

                        <div class="result-body">
                            <div class="result-name">@r.Name</div>
                            <div class="result-category">@r.Category</div>
                            @if (!string.IsNullOrWhiteSpace(r.Snippet))
                            {
                                <div class="result-snippet">@r.Snippet</div>
                            }
                        </div>

                        <div class="score-col">
                            <span class="score-badge">scor @r.Score.ToString("F4")</span>
                            <div class="score-bar-wrap">
                                <div class="score-bar" style="width:@pct%"></div>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="big">🔍</div>
                <p>Niciun document nu contine termenul <strong>„@query"</strong>.</p>
                <p style="font-size:0.85rem;">Incearca un alt cuvant-cheie (ex: <em>livrare, electric, transfer, bagaj</em>).</p>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <div class="big">📄</div>
            <p>Introduceti un termen pentru a cauta in fisele tehnice ale serviciilor.</p>
        </div>
    }
</div>
