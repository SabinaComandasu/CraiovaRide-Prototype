@model List<Proiect_Implementare_Software.Services.LuceneSearchResult>

@{
    ViewData["Title"]       = "Căutare avansată Lucene";
    ViewData["ShowMainNav"] = true;

    string query       = ViewBag.Query ?? "";
    string sort        = ViewBag.Sort  ?? "desc";
    bool   hasQuery    = !string.IsNullOrWhiteSpace(query);
    int    resultCount = ViewBag.ResultCount ?? 0;

    string oppSort     = sort == "asc" ? "desc" : "asc";
    string oppLabel    = sort == "asc"  ? "Relevanță ↓ (desc)" : "Relevanță ↑ (asc)";
    float  maxScore    = Model.Any() ? Model.Max(r => r.Score) : 1f;
}

<style>
    /* ── Layout ── */
    .lucene-page {
        max-width: 820px;
        margin: 0 auto;
        padding: 30px 20px 80px;
        font-family: system-ui, sans-serif;
    }
    .lucene-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1a5f7a;
        margin-bottom: 4px;
    }
    .lucene-subtitle {
        font-size: 0.9rem;
        color: #666;
        margin-bottom: 24px;
    }

    /* ── Search bar ── */
    .lucene-form {
        display: flex;
        gap: 8px;
        margin-bottom: 14px;
    }
    .lucene-form input {
        flex: 1;
        border: 2px solid #2f8f9d;
        border-radius: 25px;
        padding: 10px 18px;
        font-size: 0.95rem;
        outline: none;
    }
    .lucene-form input:focus { border-color: #005fa3; }
    .lucene-form button {
        background: #2f8f9d;
        color: white;
        border: none;
        border-radius: 25px;
        padding: 10px 22px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
    }
    .lucene-form button:hover { background: #005fa3; }

    /* ── Sort + meta row ── */
    .meta-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }
    .meta-row .info {
        font-size: 0.88rem;
        color: #555;
        flex: 1;
    }
    .sort-btn {
        font-size: 0.82rem;
        padding: 5px 14px;
        border-radius: 20px;
        border: 1.5px solid #2f8f9d;
        background: white;
        color: #2f8f9d;
        cursor: pointer;
        text-decoration: none;
        white-space: nowrap;
    }
    .sort-btn:hover, .sort-btn.active {
        background: #2f8f9d;
        color: white;
        text-decoration: none;
    }

    /* ── Result cards ── */
    .result-list { display: flex; flex-direction: column; gap: 14px; }

    .result-card {
        background: #f5fbff;
        border: 1.5px solid #c8e6f5;
        border-radius: 12px;
        padding: 16px 18px;
        display: flex;
        gap: 16px;
        align-items: flex-start;
        text-decoration: none;
        color: inherit;
        transition: box-shadow 0.2s, transform 0.15s;
    }
    .result-card:hover {
        box-shadow: 0 4px 14px rgba(47,143,157,.2);
        transform: translateY(-2px);
        text-decoration: none;
        color: inherit;
    }
    .result-icon { font-size: 2rem; flex-shrink: 0; line-height: 1; }
    .result-body { flex: 1; min-width: 0; }
    .result-name {
        font-size: 1rem;
        font-weight: 700;
        color: #005fa3;
        margin-bottom: 2px;
    }
    .result-category {
        font-size: 0.78rem;
        color: #888;
        margin-bottom: 6px;
    }
    .result-snippet {
        font-size: 0.83rem;
        color: #444;
        line-height: 1.45;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 580px;
    }

    /* ── Score badge + bar ── */
    .score-col { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; flex-shrink: 0; }
    .score-badge {
        background: #e4f4fd;
        color: #005fa3;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 0.78rem;
        font-weight: 700;
        white-space: nowrap;
    }
    .score-bar-wrap { width: 80px; height: 6px; background: #dde; border-radius: 3px; overflow: hidden; }
    .score-bar { height: 100%; background: linear-gradient(90deg, #2f8f9d, #005fa3); border-radius: 3px; }

    /* ── Empty / no query states ── */
    .empty-state {
        text-align: center;
        padding: 50px 20px;
        color: #999;
    }
    .empty-state .big { font-size: 3rem; }

    /* ── Info panel ── */
    .info-panel {
        margin-top: 36px;
        background: #f0f8ff;
        border: 1.5px solid #bee3f8;
        border-radius: 12px;
        overflow: hidden;
    }
    .info-panel summary {
        padding: 14px 18px;
        font-weight: 700;
        color: #1a5f7a;
        cursor: pointer;
        font-size: 0.95rem;
        list-style: none;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .info-panel summary::-webkit-details-marker { display: none; }
    .info-panel[open] summary { border-bottom: 1.5px solid #bee3f8; }
    .info-panel-body { padding: 18px 20px; font-size: 0.88rem; color: #333; line-height: 1.65; }
    .info-panel-body h4 { color: #005fa3; margin: 14px 0 4px; font-size: 0.9rem; }
    .info-panel-body code {
        background: #e0f0fa;
        border-radius: 4px;
        padding: 1px 6px;
        font-size: 0.85rem;
        color: #1a5f7a;
    }
    .formula-box {
        background: #fff;
        border: 1.5px solid #bee3f8;
        border-radius: 8px;
        padding: 12px 16px;
        font-family: monospace;
        font-size: 0.85rem;
        color: #005fa3;
        margin: 8px 0 14px;
        white-space: pre-wrap;
    }
    table.score-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 8px;
        font-size: 0.83rem;
    }
    table.score-table th {
        background: #daeef7;
        color: #1a5f7a;
        padding: 6px 10px;
        text-align: left;
    }
    table.score-table td { padding: 6px 10px; border-bottom: 1px solid #e8f4fb; vertical-align: top; }
    table.score-table tr:last-child td { border-bottom: none; }
</style>

<div class="lucene-page">
    <h1 class="lucene-title">🔬 Căutare avansată în fișele tehnice</h1>
    <p class="lucene-subtitle">Motorul Apache Lucene indexează toate documentele PDF de specificații și returnează rezultate ordonate după scorul TF-IDF.</p>

    <!-- Search form -->
    <form method="get" action="/LuceneSearch" class="lucene-form">
        <input type="text"
               name="q"
               value="@query"
               placeholder="ex: transfer aeroport, livrare express, animale, Wi-Fi..."
               autocomplete="off" />
        <input type="hidden" name="sort" value="@sort" />
        <button type="submit">🔍 Caută</button>
    </form>

    @if (hasQuery)
    {
        <!-- Meta row: result count + sort toggle -->
        <div class="meta-row">
            <span class="info">
                @if (resultCount > 0)
                {
                    <span><strong>@resultCount</strong> rezultat@(resultCount == 1 ? "" : "e") pentru <strong>„@query"</strong></span>
                }
                else
                {
                    <span>Niciun rezultat pentru <strong>„@query"</strong></span>
                }
            </span>

            @if (resultCount > 1)
            {
                <!-- current order label -->
                <span class="sort-btn active" style="cursor:default;">
                    @(sort == "asc" ? "Relevanță ↑ (asc)" : "Relevanță ↓ (desc)")
                </span>
                <!-- toggle button -->
                <a class="sort-btn"
                   href="/LuceneSearch?q=@Uri.EscapeDataString(query)&sort=@oppSort">
                    @oppLabel
                </a>
            }
        </div>

        <!-- Results -->
        @if (Model.Any())
        {
            <div class="result-list">
                @foreach (var r in Model)
                {
                    var pct = maxScore > 0 ? (int)(r.Score / maxScore * 100) : 0;

                    <a href="/Products/Details/@r.ProductId" class="result-card">
                        <span class="result-icon">@r.Icon</span>

                        <div class="result-body">
                            <div class="result-name">@r.Name</div>
                            <div class="result-category">@r.Category</div>
                            @if (!string.IsNullOrWhiteSpace(r.Snippet))
                            {
                                <div class="result-snippet">@r.Snippet</div>
                            }
                        </div>

                        <div class="score-col">
                            <span class="score-badge">scor @r.Score.ToString("F4")</span>
                            <div class="score-bar-wrap">
                                <div class="score-bar" style="width:@pct%"></div>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="big">🔍</div>
                <p>Niciun document nu conține termenul <strong>„@query"</strong>.</p>
                <p style="font-size:0.85rem;">Încearcă un alt cuvânt-cheie (ex: <em>livrare, electric, transfer, bagaj</em>).</p>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <div class="big">📄</div>
            <p>Introduceți un termen pentru a căuta în fișele tehnice ale serviciilor.</p>
        </div>
    }

    <!-- ── Lucene scoring explanation ───────────────────────────────────── -->
    <details class="info-panel" @(hasQuery ? "" : "open")>
        <summary>📐 Cum calculează Lucene scorul? (TF-IDF / Classic Similarity)</summary>
        <div class="info-panel-body">

            <p>
                Lucene.Net 4.8 folosește implicit modelul <strong>Classic Similarity</strong>, bazat pe
                <strong>TF-IDF</strong> (Term Frequency – Inverse Document Frequency).
                Formula completă a scorului pentru o interogare <em>q</em> față de un document <em>d</em> este:
            </p>

            <div class="formula-box">score(q, d) = coord(q,d) · queryNorm(q) · Σ_t [ tf(t,d) · idf(t)² · t.boost · norm(t,d) ]</div>

            <h4>Componente principale</h4>
            <table class="score-table">
                <tr>
                    <th>Factor</th>
                    <th>Formulă</th>
                    <th>Semnificație</th>
                </tr>
                <tr>
                    <td><code>tf(t, d)</code></td>
                    <td><code>√freq</code></td>
                    <td>
                        <strong>Term Frequency</strong> – rădăcina pătrată a numărului de apariții ale termenului
                        <em>t</em> în documentul <em>d</em>.
                        Un termen care apare de 4 ori contribuie cu <code>√4 = 2</code>.
                    </td>
                </tr>
                <tr>
                    <td><code>idf(t)</code></td>
                    <td><code>1 + log(N / (df+1))</code></td>
                    <td>
                        <strong>Inverse Document Frequency</strong> – penalizează termenii comuni
                        (ex. „și", „la") și premiază termenii rari.
                        <em>N</em> = numărul total de documente; <em>df</em> = câte documente conțin termenul.
                        Intră în formulă la pătrat (<code>idf²</code>).
                    </td>
                </tr>
                <tr>
                    <td><code>norm(t, d)</code></td>
                    <td><code>1 / √numTerms</code></td>
                    <td>
                        <strong>Field length norm</strong> – documentele cu câmpuri mai scurte primesc scor mai mare
                        (un termen dintr-un titlu de 3 cuvinte contează mai mult decât dintr-un paragraf lung).
                    </td>
                </tr>
                <tr>
                    <td><code>coord(q, d)</code></td>
                    <td><code>overlap / maxOverlap</code></td>
                    <td>
                        <strong>Coordonare</strong> – fracția termenilor din interogare găsiți în document.
                        O potrivire pe toți termenii e premiată față de o potrivire parțială.
                    </td>
                </tr>
                <tr>
                    <td><code>queryNorm(q)</code></td>
                    <td><code>1 / √Σ idf²</code></td>
                    <td>
                        Factor de normalizare al interogării, astfel că scorurile sunt comparabile
                        între interogări diferite (nu afectează ordinea relativă).
                    </td>
                </tr>
            </table>

            <h4>Comparație cu BM25</h4>
            <p>
                BM25 (disponibil în Lucene ca <code>BM25Similarity</code>) adaugă parametrii
                <code>k1</code> (saturație TF) și <code>b</code> (normalizare lungime):
            </p>
            <div class="formula-box">BM25(t,d) = idf(t) · [ tf · (k1+1) ] / [ tf + k1·(1 - b + b·|d|/avgdl) ]

Implicit: k1 = 1.2, b = 0.75</div>
            <p>
                Spre deosebire de TF-IDF clasic unde <code>tf</code> crește nelimitat (√freq),
                BM25 <em>saturează</em> contribuția TF: după un număr de apariții, câștigul suplimentar
                devine neglijabil. Aceasta îl face mai robust pentru documente lungi.
            </p>

            <h4>Câmpurile indexate în acest proiect</h4>
            <p>
                Fiecare fișă tehnică este indexată cu câmpurile:
                <code>name</code> · <code>category</code> · <code>description</code> · <code>pdfContent</code>.
                Textul din PDF este extras cu biblioteca <strong>PdfPig</strong> și indexat fără stocare
                (doar pentru căutare). Scorul afișat este scorul brut Lucene normalizat față de maximul din pagina curentă.
            </p>

            <p style="margin-top:12px;font-size:0.8rem;color:#888;">
                Referință: <a href="https://lucene.apache.org/core/2_9_4/scoring.html" target="_blank" rel="noopener">
                    lucene.apache.org/core/2_9_4/scoring.html
                </a>
            </p>
        </div>
    </details>
</div>
