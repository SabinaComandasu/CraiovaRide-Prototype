<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - CraiovaRide</title>
    <link rel="stylesheet" href="~/css/rides.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body>
    @RenderBody()
    @if (ViewData["ShowMainNav"] as bool? == true)
    {
        <nav class="bottom-nav">
            <a href="/Home" class="btn btn-outline-secondary mx-2">Home</a>
            <a href="/Rides" class="btn btn-outline-primary mx-2">Rides</a>
            <a href="/Account" class="btn btn-outline-success mx-2">Account</a>
        </nav>
    }
    @RenderSection("Scripts", required: false)
</body>
</html>