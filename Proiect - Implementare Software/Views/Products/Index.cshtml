@model List<Proiect_Implementare_Software.Models.Product>

@{
    ViewData["Title"] = "Products";
    ViewData["ShowMainNav"] = true;

    var grouped  = Model.GroupBy(p => p.Category).OrderBy(g => g.Key).ToList();
    bool filtered = ViewBag.IsFiltered == true;
    string query  = ViewBag.SearchQuery ?? "";
}

<link rel="stylesheet" href="~/css/products.css" />

<style>
    /* ── Search bar & autocomplete ── */
    .search-wrap {
        max-width: 560px;
        margin: 0 auto 28px auto;
        position: relative;
    }

    .search-bar-container {
        display: flex;
        gap: 8px;
    }

    .search-bar-container input {
        flex: 1;
        border: 2px solid #2f8f9d;
        border-radius: 25px;
        padding: 10px 18px;
        font-size: 0.95rem;
        outline: none;
        transition: border-color 0.2s;
    }

    .search-bar-container input:focus {
        border-color: #005fa3;
    }

    .search-bar-container button {
        background-color: #2f8f9d;
        color: white;
        border: none;
        border-radius: 25px;
        padding: 10px 22px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .search-bar-container button:hover {
        background-color: #005fa3;
    }

    /* Autocomplete dropdown */
    .autocomplete-list {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        right: 60px; /* leave space for the button */
        background: white;
        border: 1.5px solid #c8e6f5;
        border-radius: 14px;
        box-shadow: 0 6px 20px rgba(0,95,163,0.13);
        z-index: 999;
        overflow: hidden;
        display: none;
    }

    .autocomplete-item {
        padding: 10px 18px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.92rem;
        color: #1a5f7a;
        transition: background 0.15s;
        text-decoration: none;
    }

    .autocomplete-item:hover,
    .autocomplete-item.active {
        background: #e4f4fd;
        color: #005fa3;
        text-decoration: none;
    }

    .autocomplete-item .ac-icon {
        font-size: 18px;
        flex-shrink: 0;
    }

    /* ── Shared card styles ── */
    .search-clear-btn {
        background: none;
        border: none;
        color: #2f8f9d;
        font-size: 0.85rem;
        cursor: pointer;
        text-decoration: underline;
        padding: 0;
        margin-top: 6px;
        display: block;
        text-align: center;
    }

    .search-result-info {
        text-align: center;
        margin-bottom: 20px;
        font-size: 0.92rem;
        color: #555;
    }

    .search-result-info strong {
        color: #005fa3;
    }

    .no-results {
        text-align: center;
        padding: 40px 20px;
        color: #888;
        font-size: 1rem;
    }

    .search-results-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 16px;
        margin-top: 10px;
    }

    .service-card {
        display: block;
        text-decoration: none;
        color: inherit;
        background: #f5fbff;
        border: 1.5px solid #c8e6f5;
        border-radius: 12px;
        padding: 16px 12px 14px;
        text-align: center;
        transition: box-shadow 0.2s ease, transform 0.2s ease, background 0.2s ease;
        user-select: none;
    }

    .service-card:hover {
        background: #e4f4fd;
        box-shadow: 0 4px 12px rgba(47,143,157,0.2);
        transform: translateY(-3px);
        color: inherit;
        text-decoration: none;
    }

    .service-price {
        display: block;
        font-size: 0.85rem;
        font-weight: 700;
        color: #005fa3;
        margin-top: 4px;
    }

    .service-pdf-link {
        display: inline-block;
        margin-top: 6px;
        font-size: 0.78rem;
        color: #2f8f9d;
        text-decoration: none;
        border: 1px solid #2f8f9d;
        border-radius: 0.5rem;
        padding: 2px 8px;
        transition: background-color 0.2s ease, color 0.2s ease;
    }

    .service-pdf-link:hover {
        background-color: #2f8f9d;
        color: white;
    }
</style>

<div class="products-container">
    <h1 class="products-title">Serviciile noastre</h1>
    <p class="products-subtitle">Descoperă toate opțiunile disponibile în aplicația CraiovaRide</p>

    <!-- Search bar (BM25) + autocomplete dropdown -->
    <div class="search-wrap">
        <form method="get" action="/Products/Index" class="search-bar-container" id="searchForm">
            <input type="text"
                   id="searchInput"
                   name="q"
                   value="@query"
                   placeholder="Caută un serviciu..."
                   autocomplete="off" />
            <button type="submit">🔍 Caută</button>
        </form>
        <div class="autocomplete-list" id="acList"></div>
    </div>

    @if (filtered)
    {
        <div class="search-result-info">
            @if (Model.Any())
            {
                <span>@Model.Count rezultat@(Model.Count == 1 ? "" : "e") pentru <strong>„@query"</strong></span>
            }
            <br />
            <a href="/Products/Index" class="search-clear-btn">✕ Șterge filtrele</a>
        </div>
    }

    @if (filtered)
    {
        <!-- Search results: flat grid, no category grouping -->
        @if (Model.Any())
        {
            <div class="search-results-grid">
                @foreach (var product in Model)
                {
                    <a href="/Products/Details/@product.ProductID" class="service-card">
                        <span class="service-icon">@product.Icon</span>
                        <span class="service-name">@product.Name</span>
                        <span style="font-size:0.78rem;color:#888;">@product.Category</span>
                        <span class="service-price">@product.Price.ToString("F2") RON</span>
                        @if (!string.IsNullOrEmpty(product.PdfPath))
                        {
                            var fn = product.PdfPath.TrimStart('/').Replace("pdfs/", "");
                            <span class="service-pdf-link" onclick="event.preventDefault();window.open('/Products/DownloadPdf?fileName=@fn','_blank')">📄 PDF</span>
                        }
                    </a>
                }
            </div>
        }
        else
        {
            <div class="no-results">
                <p>Niciun serviciu găsit pentru „<strong>@query</strong>".</p>
                <p style="font-size:0.85rem;">Încearcă un alt termen de căutare.</p>
            </div>
        }
    }
    else
    {
        <!-- Normal view: grouped by category -->
        @foreach (var group in grouped)
        {
            <div class="category-section">
                <div class="category-header">
                    <span class="category-icon">
                        @{
                            var icon = group.Key switch
                            {
                                "Transport persoane" => "🚗",
                                "Livrare"            => "📦",
                                "Inchirieri"         => "🛴",
                                "Servicii speciale"  => "⭐",
                                _                    => "📋"
                            };
                        }
                        @icon
                    </span>
                    <h2 class="category-title">@group.Key</h2>
                </div>
                <div class="services-grid">
                    @foreach (var product in group.OrderBy(p => p.Name))
                    {
                        <a href="/Products/Details/@product.ProductID" class="service-card">
                            <span class="service-icon">@product.Icon</span>
                            <span class="service-name">@product.Name</span>
                            <span class="service-price">@product.Price.ToString("F2") RON</span>
                            @if (!string.IsNullOrEmpty(product.PdfPath))
                            {
                                var fileName = product.PdfPath.TrimStart('/').Replace("pdfs/", "");
                                <span class="service-pdf-link"
                                      onclick="event.preventDefault();window.open('/Products/DownloadPdf?fileName=@fileName','_blank')">📄 PDF</span>
                            }
                        </a>
                    }
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <p>Nu există produse disponibile momentan.</p>
            </div>
        }
    }
</div>

@section Scripts {
<script>
(function () {
    const input  = document.getElementById('searchInput');
    const acList = document.getElementById('acList');
    let activeIdx = -1;
    let debounceTimer = null;

    if (!input || !acList) return;

    input.addEventListener('input', function () {
        clearTimeout(debounceTimer);
        const q = input.value.trim();
        if (q.length < 1) { hideList(); return; }

        // Debounce 200ms to avoid too many requests
        debounceTimer = setTimeout(() => fetchSuggestions(q), 200);
    });

    input.addEventListener('keydown', function (e) {
        const items = acList.querySelectorAll('.autocomplete-item');
        if (!items.length) return;

        if (e.key === 'ArrowDown') {
            e.preventDefault();
            activeIdx = Math.min(activeIdx + 1, items.length - 1);
            updateActive(items);
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            activeIdx = Math.max(activeIdx - 1, -1);
            updateActive(items);
        } else if (e.key === 'Enter' && activeIdx >= 0) {
            e.preventDefault();
            items[activeIdx].click();
        } else if (e.key === 'Escape') {
            hideList();
        }
    });

    document.addEventListener('click', function (e) {
        if (!acList.contains(e.target) && e.target !== input) hideList();
    });

    function fetchSuggestions(q) {
        fetch('/Products/Autocomplete?q=' + encodeURIComponent(q))
            .then(r => r.json())
            .then(data => {
                renderList(data);
            })
            .catch(() => hideList());
    }

    function renderList(items) {
        acList.innerHTML = '';
        activeIdx = -1;

        if (!items || items.length === 0) { hideList(); return; }

        items.forEach(function (item) {
            const a = document.createElement('a');
            a.className = 'autocomplete-item';
            a.href = '/Products/Details/' + item.productID;
            a.innerHTML = '<span class="ac-icon">' + item.icon + '</span>'
                        + '<span>' + escapeHtml(item.name) + '</span>';
            acList.appendChild(a);
        });

        acList.style.display = 'block';
    }

    function updateActive(items) {
        items.forEach((el, i) => el.classList.toggle('active', i === activeIdx));
    }

    function hideList() {
        acList.style.display = 'none';
        acList.innerHTML = '';
        activeIdx = -1;
    }

    function escapeHtml(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
}());
</script>
}
