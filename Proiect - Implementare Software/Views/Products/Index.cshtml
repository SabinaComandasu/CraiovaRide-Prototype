@model List<Proiect_Implementare_Software.Models.Product>

@{
    ViewData["Title"] = "Products";
    ViewData["ShowMainNav"] = true;

    var grouped   = Model.GroupBy(p => p.Category).OrderBy(g => g.Key).ToList();
    bool filtered = ViewBag.IsFiltered == true;
    string query  = ViewBag.SearchQuery ?? "";
}

<link rel="stylesheet" href="~/css/products.css" />

<style>
    .search-bar-container {
        max-width: 560px;
        margin: 0 auto 28px auto;
        display: flex;
        gap: 8px;
    }

    .search-bar-container input {
        flex: 1;
        border: 2px solid #2f8f9d;
        border-radius: 25px;
        padding: 10px 18px;
        font-size: 0.95rem;
        outline: none;
        transition: border-color 0.2s;
    }

    .search-bar-container input:focus {
        border-color: #005fa3;
    }

    .search-bar-container button {
        background-color: #2f8f9d;
        color: white;
        border: none;
        border-radius: 25px;
        padding: 10px 22px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .search-bar-container button:hover {
        background-color: #005fa3;
    }

    .search-clear-btn {
        background: none;
        border: none;
        color: #2f8f9d;
        font-size: 0.85rem;
        cursor: pointer;
        text-decoration: underline;
        padding: 0;
        margin-top: 6px;
        display: block;
        text-align: center;
    }

    .search-result-info {
        text-align: center;
        margin-bottom: 20px;
        font-size: 0.92rem;
        color: #555;
    }

    .search-result-info strong {
        color: #005fa3;
    }

    .no-results {
        text-align: center;
        padding: 40px 20px;
        color: #888;
        font-size: 1rem;
    }

    /* When showing search results, flatten the category grouping */
    .search-results-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 16px;
        margin-top: 10px;
    }

    .service-card {
        cursor: default;
        position: relative;
    }

    .service-price {
        display: block;
        font-size: 0.85rem;
        font-weight: 700;
        color: #005fa3;
        margin-top: 4px;
    }

    .service-pdf-link {
        display: inline-block;
        margin-top: 6px;
        font-size: 0.78rem;
        color: #2f8f9d;
        text-decoration: none;
        border: 1px solid #2f8f9d;
        border-radius: 0.5rem;
        padding: 2px 8px;
        transition: background-color 0.2s ease, color 0.2s ease;
    }

    .service-pdf-link:hover {
        background-color: #2f8f9d;
        color: white;
    }
</style>

<div class="products-container">
    <h1 class="products-title">Serviciile noastre</h1>
    <p class="products-subtitle">Descoperă toate opțiunile disponibile în aplicația CraiovaRide</p>

    <!-- Search bar (BM25) -->
    <form method="get" action="/Products/Index" class="search-bar-container">
        <input type="text"
               name="q"
               value="@query"
               placeholder="Caută un serviciu..."
               autocomplete="off" />
        <button type="submit">🔍 Caută</button>
    </form>

    @if (filtered)
    {
        <div class="search-result-info">
            @if (Model.Any())
            {
                <span>@Model.Count rezultat@(Model.Count == 1 ? "" : "e") pentru <strong>„@query"</strong></span>
            }
            <br />
            <a href="/Products/Index" class="search-clear-btn">✕ Șterge filtrele</a>
        </div>
    }

    @if (filtered)
    {
        <!-- Search results: flat grid, no category grouping -->
        @if (Model.Any())
        {
            <div class="search-results-grid">
                @foreach (var product in Model)
                {
                    <div class="service-card">
                        <span class="service-icon">@product.Icon</span>
                        <span class="service-name">@product.Name</span>
                        <span style="font-size:0.78rem;color:#888;">@product.Category</span>
                        <span class="service-price">@product.Price.ToString("F2") RON</span>
                        @if (!string.IsNullOrEmpty(product.PdfPath))
                        {
                            var fn = product.PdfPath.TrimStart('/').Replace("pdfs/", "");
                            <a href="/Products/DownloadPdf?fileName=@fn" class="service-pdf-link" target="_blank">📄 Detalii PDF</a>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-results">
                <p>Niciun serviciu găsit pentru „<strong>@query</strong>".</p>
                <p style="font-size:0.85rem;">Încearcă un alt termen de căutare.</p>
            </div>
        }
    }
    else
    {
        <!-- Normal view: grouped by category -->
        @foreach (var group in grouped)
        {
            <div class="category-section">
                <div class="category-header">
                    <span class="category-icon">
                        @{
                            var icon = group.Key switch
                            {
                                "Transport persoane" => "🚗",
                                "Livrare" => "📦",
                                "Inchirieri" => "🛴",
                                "Servicii speciale" => "⭐",
                                _ => "📋"
                            };
                        }
                        @icon
                    </span>
                    <h2 class="category-title">@group.Key</h2>
                </div>
                <div class="services-grid">
                    @foreach (var product in group.OrderBy(p => p.Name))
                    {
                        <div class="service-card">
                            <span class="service-icon">@product.Icon</span>
                            <span class="service-name">@product.Name</span>
                            <span class="service-price">@product.Price.ToString("F2") RON</span>
                            @if (!string.IsNullOrEmpty(product.PdfPath))
                            {
                                var fileName = product.PdfPath.TrimStart('/').Replace("pdfs/", "");
                                <a href="/Products/DownloadPdf?fileName=@fileName"
                                   class="service-pdf-link"
                                   target="_blank">📄 Detalii PDF</a>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <p>Nu există produse disponibile momentan.</p>
            </div>
        }
    }
</div>
